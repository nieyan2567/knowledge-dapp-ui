# Replace these values before your first startup.

# Public IP or domain name that other peers can reach.
NODE_HOST=203.0.113.10

# Bootnode enode provided by the network administrator.
BOOTNODE_ENODE=enode://replace-with-bootnode-enode@203.0.113.20:30303

# Optional overrides.
BESU_IMAGE=hyperledger/besu:latest
RPC_HTTP_PORT=8545
P2P_PORT=30303
