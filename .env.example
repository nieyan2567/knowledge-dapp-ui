# Copy this file to `.env.local` for local development.
# `NODE_ENV` is usually set by Next.js automatically:
# - `npm run dev` -> development
# - tests -> test
# - production deployment -> production

# -----------------------------------------------------------------------------
# Public client configuration
# These values are exposed to the browser with the NEXT_PUBLIC_ prefix.
# Localhost defaults are fine for local development only.
# In production, the URL fields below must be set explicitly and must not point
# to localhost / 127.0.0.1.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BESU_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_BESU_CHAIN_ID=20260
# Blockscout explorer URL.
NEXT_PUBLIC_BLOCKSCOUT_URL=http://127.0.0.1:8182
NEXT_PUBLIC_IPFS_GATEWAY_URL=http://127.0.0.1:8080/ipfs
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=replace_with_walletconnect_project_id

# -----------------------------------------------------------------------------
# Upload and IPFS
# UPLOAD_PROVIDER currently supports only `local`.
# The IPFS URLs below can use localhost in development.
# In production, all URL fields here must be set explicitly and must not point
# to localhost / 127.0.0.1.
# UPLOAD_AUTH_SECRET is required when NODE_ENV=production.
# -----------------------------------------------------------------------------
UPLOAD_PROVIDER=local
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080/ipfs
UPLOAD_AUTH_SECRET=replace_with_a_long_random_secret
UPLOAD_AUTH_NONCE_TTL_SECONDS=300
UPLOAD_AUTH_SESSION_TTL_SECONDS=7200
UPLOAD_MAX_FILE_SIZE_BYTES=536870912

# -----------------------------------------------------------------------------
# Redis and API rate limiting
# REDIS_URL is optional, but recommended when you want shared rate limiting or
# multiple app instances. Leave it blank to disable Redis-backed storage.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

DATABASE_URL=postgresql://knowledge:knowledge@127.0.0.1:5432/knowledge_dapp
BESU_ADMIN_RPC_URL=http://127.0.0.1:8545
BESU_ADMIN_RPC_TOKEN=replace_with_besu_admin_token
ADMIN_ADDRESSES=0x1234567890abcdef1234567890abcdef12345678
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_MAX=120

# -----------------------------------------------------------------------------
# Observability and alerts
# OBS_ALERT_WEBHOOK_URL is required when NODE_ENV=production.
# OBS_ALERT_WEBHOOK_TOKEN is optional unless your webhook endpoint requires it.
# -----------------------------------------------------------------------------
OBS_SERVICE_NAME=knowledge-dapp-ui
OBS_DEPLOYMENT_ENV=development
OBS_LOG_LEVEL=info
OBS_ALERT_WEBHOOK_URL=https://example.com/alerts
OBS_ALERT_WEBHOOK_TOKEN=replace_with_alert_webhook_token
OBS_ALERT_MIN_SEVERITY=error
OBS_ALERT_DEDUP_WINDOW_SECONDS=300
OBS_CLIENT_ERROR_SAMPLE_RATE=1

# -----------------------------------------------------------------------------
# Faucet and automated system operations
# FAUCET_AUTH_SIGNER_PRIVATE_KEY signs Faucet claim authorizations.
# FAUCET_RELAYER_PRIVATE_KEY submits claim and rebalance transactions.
# FAUCET_TOP_UP_FUNDER_PRIVATE_KEY funds the relayer gas wallet when the
# maintenance job detects that the relayer balance dropped below threshold.
# SYSTEM_API_TOKEN protects internal system maintenance endpoints and falls back
# to REBALANCE_API_TOKEN when omitted.
# REBALANCE_API_TOKEN protects the internal rebalance endpoint.
# Set both to strong private values before enabling those features outside local
# development.
# -----------------------------------------------------------------------------
FAUCET_AUTH_SIGNER_PRIVATE_KEY=replace_with_faucet_auth_signer_private_key
FAUCET_RELAYER_PRIVATE_KEY=replace_with_faucet_relayer_private_key
FAUCET_TOP_UP_FUNDER_PRIVATE_KEY=replace_with_faucet_top_up_funder_private_key
SYSTEM_API_TOKEN=replace_with_system_api_token
REBALANCE_API_TOKEN=replace_with_rebalance_api_token
FAUCET_AMOUNT=2
FAUCET_MIN_BALANCE=1
FAUCET_RELAYER_ALERT_MIN_BALANCE=0.05
FAUCET_RELAYER_TOP_UP_AMOUNT=0.2
FAUCET_VAULT_ALERT_MIN_BALANCE=20
FAUCET_COOLDOWN_HOURS=24
FAUCET_LOCK_TTL_SECONDS=60
FAUCET_NONCE_TTL_SECONDS=300
FAUCET_NONCE_RATE_LIMIT_WINDOW_SECONDS=60
FAUCET_NONCE_RATE_LIMIT_MAX=5
FAUCET_CLAIM_RATE_LIMIT_WINDOW_SECONDS=3600
FAUCET_CLAIM_RATE_LIMIT_MAX=10
