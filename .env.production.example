# Copy this file to `.env.production.local` before running `npm run build`
# or deploying with `NODE_ENV=production`.
#
# These values are validated in production:
# - URL fields below must be explicitly set
# - URL fields below must not point to localhost / 127.0.0.1 / ::1
# - UPLOAD_AUTH_SECRET must be non-empty
# - OBS_ALERT_WEBHOOK_URL must be non-empty

# -----------------------------------------------------------------------------
# Public client configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BESU_RPC_URL=https://rpc.example.com
NEXT_PUBLIC_BESU_CHAIN_ID=20260
NEXT_PUBLIC_BLOCKSCOUT_URL=https://scan.example.com
NEXT_PUBLIC_IPFS_GATEWAY_URL=https://ipfs.example.com/ipfs
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=replace_with_walletconnect_project_id

# -----------------------------------------------------------------------------
# Upload and IPFS
# -----------------------------------------------------------------------------
UPLOAD_PROVIDER=local
IPFS_API_URL=https://ipfs-api.example.com
IPFS_GATEWAY_URL=https://ipfs.example.com/ipfs
UPLOAD_AUTH_SECRET=replace_with_a_long_random_secret
UPLOAD_AUTH_NONCE_TTL_SECONDS=300
UPLOAD_AUTH_SESSION_TTL_SECONDS=7200
UPLOAD_MAX_FILE_SIZE_BYTES=536870912

# -----------------------------------------------------------------------------
# Redis and API rate limiting
# -----------------------------------------------------------------------------
REDIS_URL=redis://user:password@redis.example.com:6379
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_MAX=120

# -----------------------------------------------------------------------------
# Observability and alerts
# -----------------------------------------------------------------------------
OBS_SERVICE_NAME=knowledge-dapp-ui
OBS_DEPLOYMENT_ENV=production
OBS_LOG_LEVEL=info
OBS_ALERT_WEBHOOK_URL=https://alerts.example.com/webhook
OBS_ALERT_WEBHOOK_TOKEN=replace_with_alert_webhook_token
OBS_ALERT_MIN_SEVERITY=error
OBS_ALERT_DEDUP_WINDOW_SECONDS=300
OBS_CLIENT_ERROR_SAMPLE_RATE=1

# -----------------------------------------------------------------------------
# Faucet and automated system operations
# Keep these empty if you do not plan to enable faucet/rebalance in production.
# -----------------------------------------------------------------------------
FAUCET_AUTH_SIGNER_PRIVATE_KEY=
FAUCET_RELAYER_PRIVATE_KEY=
FAUCET_TOP_UP_FUNDER_PRIVATE_KEY=
SYSTEM_API_TOKEN=
REBALANCE_API_TOKEN=
FAUCET_AMOUNT=2
FAUCET_MIN_BALANCE=1
FAUCET_RELAYER_ALERT_MIN_BALANCE=0.05
FAUCET_RELAYER_TOP_UP_AMOUNT=0.2
FAUCET_VAULT_ALERT_MIN_BALANCE=20
FAUCET_COOLDOWN_HOURS=24
FAUCET_LOCK_TTL_SECONDS=60
FAUCET_NONCE_TTL_SECONDS=300
FAUCET_NONCE_RATE_LIMIT_WINDOW_SECONDS=60
FAUCET_NONCE_RATE_LIMIT_MAX=5
FAUCET_CLAIM_RATE_LIMIT_WINDOW_SECONDS=3600
FAUCET_CLAIM_RATE_LIMIT_MAX=10
